#!/usr/bin/env bash
set -uo pipefail

if [[ "${1:-}" == "--popup" ]]; then
    count=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | wc -l | tr -d ' ')
    max_name=$(tmux list-sessions -F '#{session_name}' 2>/dev/null | awk '{l=length; if(l>m) m=l} END{print m}')
    h=$((count + 10))
    w=$((max_name + 20))
    [[ $h -lt 15 ]] && h=15
    [[ $w -lt 50 ]] && w=50
    tmux display-popup -w "$w" -h "$h" -E "$0"
    exit 0
fi

tmux_color() {
    local hex
    hex=$(tmux show-options -gv "$1" 2>/dev/null)
    hex="${hex#\#}"
    printf '\033[38;2;%d;%d;%dm' "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

CLR_RED=$(tmux_color @thm_red)
CLR_YELLOW=$(tmux_color @thm_yellow)
CLR_GREEN=$(tmux_color @thm_green)
CLR_BLUE=$(tmux_color @thm_blue)
CLR_DIM=$(tmux_color @thm_overlay_0)
CLR_BOLD=$'\033[1m'
CLR_RESET=$'\033[0m'

DOT="●"

STATE_ERROR=1
STATE_APPROVAL=2
STATE_FOLLOWUP=3
STATE_WORKING=4
STATE_IDLE=5
STATE_NONE=9

detect_agent_state() {
    local pane_id="$1"
    local c
    c=$(tmux capture-pane -t "$pane_id" -p 2>/dev/null) || {
        _state=$STATE_WORKING; return
    }

    [[ "$c" == *"CLI hang:"* ]] && { _state=$STATE_ERROR; return; }

    if [[ "$c" == *"Run this command?"* ]] || \
       [[ "$c" == *"Run this MCP tool?"* ]] || \
       [[ "$c" == *"Delete this file?"* ]] || \
       [[ "$c" == *"Write to this file?"* ]] || \
       [[ "$c" == *"outside the sandbox?"* ]] || \
       [[ "$c" == *"Ready to build?"* ]]; then
        _state=$STATE_APPROVAL; return
    fi

    [[ "$c" =~ Thinking.*[0-9]+\.[0-9]+% ]] && { _state=$STATE_WORKING; return; }

    if [[ "$c" == *"ctrl+r to review"* ]] || \
       [[ "$c" == *"Add a follow-up"* ]] || \
       [[ "$c" == *"ctrl-r to respond"* ]]; then
        _state=$STATE_FOLLOWUP; return
    fi

    [[ "$c" == *"Plan, search, build anything"* ]] && { _state=$STATE_IDLE; return; }

    _state=$STATE_WORKING
}

build_list() {
    local current_session
    current_session=$(tmux display-message -p '#S')

    local agent_pids
    agent_pids=" $(ps -eo pid=,ppid=,args= 2>/dev/null \
        | awk '/cursor-agent/ {print $1; print $2}' | tr '\n' ' ') "

    local -a names=() activities=() prios=() dots_arr=() dot_counts=()
    local max_len=0

    while IFS=$'\t' read -r sn act; do
        names+=("$sn")
        activities+=("$act")
        prios+=("$STATE_NONE")
        dots_arr+=("")
        dot_counts+=(0)
        [[ "${#sn}" -gt "$max_len" ]] && max_len=${#sn}
    done < <(tmux list-sessions -F '#{session_name}	#{session_activity}' 2>/dev/null)

    while IFS=$'\t' read -r session pane_id pane_pid; do
        [[ "$agent_pids" != *" ${pane_pid} "* ]] && continue
        detect_agent_state "$pane_id"
        for idx in "${!names[@]}"; do
            [[ "${names[$idx]}" != "$session" ]] && continue
            case "$_state" in
                "$STATE_ERROR")    dots_arr[$idx]+="${CLR_RED}${DOT}${CLR_RESET}" ;;
                "$STATE_APPROVAL") dots_arr[$idx]+="${CLR_YELLOW}${DOT}${CLR_RESET}" ;;
                "$STATE_FOLLOWUP") dots_arr[$idx]+="${CLR_BLUE}${DOT}${CLR_RESET}" ;;
                "$STATE_WORKING")  dots_arr[$idx]+="${CLR_GREEN}${DOT}${CLR_RESET}" ;;
                "$STATE_IDLE")     dots_arr[$idx]+="${CLR_DIM}${DOT}${CLR_RESET}" ;;
            esac
            dot_counts[$idx]=$(( ${dot_counts[$idx]} + 1 ))
            [[ "$_state" -lt "${prios[$idx]}" ]] && prios[$idx]=$_state
            break
        done
    done < <(tmux list-panes -a -F '#{session_name}	#{pane_id}	#{pane_pid}' 2>/dev/null)

    local line_width=$(($(tput cols) - 4))

    for i in "${!names[@]}"; do
        local sn="${names[$i]}"
        local prefix="  "
        [[ "$sn" == "$current_session" ]] && prefix="* "

        local dc=${dot_counts[$i]}
        local gap_width=$((line_width - ${#prefix} - ${#sn} - dc))
        [[ $gap_width -lt 2 ]] && gap_width=2
        local gap=$(printf '%*s' "$gap_width" "")

        local display
        if [[ "$sn" == "$current_session" ]]; then
            display="${CLR_BOLD}${prefix}${sn}${CLR_RESET}${gap}${dots_arr[$i]}"
        else
            display="${prefix}${sn}${gap}${dots_arr[$i]}"
        fi

        printf '%d\t%s\t%s\t%s\n' "${prios[$i]}" "${activities[$i]}" "$sn" "$display"
    done
}

create_session() {
    if ! command -v zoxide &>/dev/null; then
        return 1
    fi

    local dir
    dir=$(zoxide query -l 2>/dev/null | fzf \
        --prompt="Directory: " \
        --height=100% \
        --layout=reverse \
        --border \
        --no-info) || return 1

    [[ -z "$dir" ]] && return 1

    local name
    name=$(basename "$dir" | sed 's/^\.//; s/[./]/-/g')

    if tmux has-session -t "=$name" 2>/dev/null; then
        tmux switch-client -t "=$name"
    else
        tmux new-session -d -s "$name" -c "$dir"
        tmux switch-client -t "=$name"
    fi
}

kill_session() {
    local target="$1"
    local current_session
    current_session=$(tmux display-message -p '#S')

    [[ "$target" == "$current_session" ]] && return 0

    tmux kill-session -t "=$target" 2>/dev/null
    return 0
}

main() {
    local legend="  ${CLR_RED}${DOT}${CLR_RESET} err   ${CLR_YELLOW}${DOT}${CLR_RESET} approve   ${CLR_BLUE}${DOT}${CLR_RESET} done   ${CLR_GREEN}${DOT}${CLR_RESET} work"
    local bindings="  ${CLR_DIM}enter:switch  ctrl-n:new  ctrl-x:kill${CLR_RESET}"
    local header
    header=$(printf '%s\n%s\n' "$legend" "$bindings")

    while true; do
        local list
        list=$(build_list | sort -t$'\t' -k1,1n -k2,2rn)

        [[ -z "$list" ]] && exit 0

        local result
        result=$(printf '%s\n' "$list" | fzf \
            --ansi \
            --delimiter=$'\t' \
            --with-nth=4 \
            --expect=ctrl-n,ctrl-x \
            --prompt=" " \
            --height=100% \
            --layout=reverse \
            --border \
            --no-info \
            --header="$header" \
            --header-first) || exit 0

        local key selection
        key=$(head -1 <<< "$result")
        selection=$(sed -n '2p' <<< "$result")

        case "$key" in
            ctrl-n)
                create_session && exit 0
                ;;
            ctrl-x)
                if [[ -n "$selection" ]]; then
                    kill_session "$(printf '%s' "$selection" | cut -f3)"
                fi
                ;;
            *)
                [[ -z "$selection" ]] && continue
                local session_name
                session_name=$(printf '%s' "$selection" | cut -f3)
                tmux switch-client -t "=$session_name" 2>/dev/null
                exit 0
                ;;
        esac
    done
}

main
