#!/usr/bin/env bash
set -uo pipefail

tmux_color() {
    local hex
    hex=$(tmux show-options -gv "$1" 2>/dev/null)
    hex="${hex#\#}"
    printf '\033[38;2;%d;%d;%dm' "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

CLR_RED=$(tmux_color @thm_red)
CLR_YELLOW=$(tmux_color @thm_yellow)
CLR_GREEN=$(tmux_color @thm_green)
CLR_BLUE=$(tmux_color @thm_blue)
CLR_DIM=$(tmux_color @thm_overlay_0)
CLR_BOLD=$'\033[1m'
CLR_RESET=$'\033[0m'

DOT="●"

STATE_ERROR=1
STATE_APPROVAL=2
STATE_FOLLOWUP=3
STATE_WORKING=4
STATE_IDLE=5
STATE_NONE=9

detect_agent_state() {
    local pane_id="$1"
    local c
    c=$(tmux capture-pane -t "$pane_id" -p 2>/dev/null) || {
        _state=$STATE_WORKING; return
    }

    [[ "$c" == *"CLI hang:"* ]] && { _state=$STATE_ERROR; return; }

    if [[ "$c" == *"Run this command?"* ]] || \
       [[ "$c" == *"Run this MCP tool?"* ]] || \
       [[ "$c" == *"Delete this file?"* ]] || \
       [[ "$c" == *"Write to this file?"* ]] || \
       [[ "$c" == *"outside the sandbox?"* ]] || \
       [[ "$c" == *"Ready to build?"* ]]; then
        _state=$STATE_APPROVAL; return
    fi

    [[ "$c" =~ Thinking.*[0-9]+\.[0-9]+% ]] && { _state=$STATE_WORKING; return; }

    if [[ "$c" == *"ctrl+r to review"* ]] || \
       [[ "$c" == *"Add a follow-up"* ]] || \
       [[ "$c" == *"ctrl-r to respond"* ]]; then
        _state=$STATE_FOLLOWUP; return
    fi

    [[ "$c" == *"Plan, search, build anything"* ]] && { _state=$STATE_IDLE; return; }

    _state=$STATE_WORKING
}

build_list() {
    local current_session
    current_session=$(tmux display-message -p '#S')

    # Single ps call → set of PIDs that are (or parent) a cursor-agent process
    local agent_pids
    agent_pids=" $(ps -eo pid=,ppid=,args= 2>/dev/null \
        | awk '/cursor-agent/ {print $1; print $2}' | tr '\n' ' ') "

    # Single tmux call for all panes across all sessions
    local -a names=() prios=() dots_arr=()
    local max_len=0
    local prev_session="" dots="" max_priority=$STATE_NONE

    while IFS=$'\t' read -r session pane_id pane_pid; do
        if [[ "$session" != "$prev_session" ]]; then
            if [[ -n "$prev_session" ]]; then
                names+=("$prev_session")
                prios+=("$max_priority")
                dots_arr+=("$dots")
                [[ "${#prev_session}" -gt "$max_len" ]] && max_len=${#prev_session}
            fi
            dots=""
            max_priority=$STATE_NONE
            prev_session="$session"
        fi

        if [[ "$agent_pids" == *" ${pane_pid} "* ]]; then
            detect_agent_state "$pane_id"
            case "$_state" in
                "$STATE_ERROR")    dots+="${CLR_RED}${DOT}${CLR_RESET}" ;;
                "$STATE_APPROVAL") dots+="${CLR_YELLOW}${DOT}${CLR_RESET}" ;;
                "$STATE_FOLLOWUP") dots+="${CLR_BLUE}${DOT}${CLR_RESET}" ;;
                "$STATE_WORKING")  dots+="${CLR_GREEN}${DOT}${CLR_RESET}" ;;
                "$STATE_IDLE")     dots+="${CLR_DIM}${DOT}${CLR_RESET}" ;;
            esac
            [[ "$_state" -lt "$max_priority" ]] && max_priority=$_state
        fi
    done < <(tmux list-panes -a -F '#{session_name}	#{pane_id}	#{pane_pid}' 2>/dev/null)

    if [[ -n "$prev_session" ]]; then
        names+=("$prev_session")
        prios+=("$max_priority")
        dots_arr+=("$dots")
        [[ "${#prev_session}" -gt "$max_len" ]] && max_len=${#prev_session}
    fi

    local col=$((max_len + 4))

    for i in "${!names[@]}"; do
        local sn="${names[$i]}"
        local visible="  ${sn}"
        if [[ "$sn" == "$current_session" ]]; then
            visible="* ${sn}"
        fi

        local pad=$((col - ${#visible}))
        local gap=$(printf '%*s' "$pad" "")

        local display
        if [[ "$sn" == "$current_session" ]]; then
            display="${CLR_BOLD}${visible}${CLR_RESET}${gap}${dots_arr[$i]}"
        else
            display="${visible}${gap}${dots_arr[$i]}"
        fi

        printf '%d\t%s\t%s\n' "${prios[$i]}" "$sn" "$display"
    done
}

create_session() {
    if ! command -v zoxide &>/dev/null; then
        return 1
    fi

    local dir
    dir=$(zoxide query -l 2>/dev/null | fzf \
        --prompt="Directory: " \
        --height=100% \
        --layout=reverse \
        --border \
        --no-info) || return 1

    [[ -z "$dir" ]] && return 1

    local name
    name=$(basename "$dir" | sed 's/^\.//; s/[./]/-/g')

    if tmux has-session -t "=$name" 2>/dev/null; then
        tmux switch-client -t "=$name"
    else
        tmux new-session -d -s "$name" -c "$dir"
        tmux switch-client -t "=$name"
    fi
}

kill_session() {
    local target="$1"
    local current_session
    current_session=$(tmux display-message -p '#S')

    [[ "$target" == "$current_session" ]] && return 0

    tmux kill-session -t "=$target" 2>/dev/null
    return 0
}

main() {
    local legend="  ${CLR_RED}${DOT}${CLR_RESET} err   ${CLR_YELLOW}${DOT}${CLR_RESET} approve   ${CLR_BLUE}${DOT}${CLR_RESET} done   ${CLR_GREEN}${DOT}${CLR_RESET} work   ${CLR_DIM}${DOT}${CLR_RESET} idle"
    local bindings="  ${CLR_DIM}enter:switch  ctrl-n:new  ctrl-x:kill${CLR_RESET}"
    local header
    header=$(printf '%s\n%s\n' "$legend" "$bindings")

    while true; do
        local list
        list=$(build_list | sort -t$'\t' -k1,1n)

        [[ -z "$list" ]] && exit 0

        local result
        result=$(printf '%s\n' "$list" | fzf \
            --ansi \
            --delimiter=$'\t' \
            --with-nth=3 \
            --expect=ctrl-n,ctrl-x \
            --prompt=" " \
            --height=100% \
            --layout=reverse \
            --border \
            --no-info \
            --header="$header" \
            --header-first) || exit 0

        local key selection
        key=$(head -1 <<< "$result")
        selection=$(sed -n '2p' <<< "$result")

        case "$key" in
            ctrl-n)
                create_session && exit 0
                ;;
            ctrl-x)
                if [[ -n "$selection" ]]; then
                    kill_session "$(printf '%s' "$selection" | cut -f2)"
                fi
                ;;
            *)
                [[ -z "$selection" ]] && continue
                local session_name
                session_name=$(printf '%s' "$selection" | cut -f2)
                tmux switch-client -t "=$session_name" 2>/dev/null
                exit 0
                ;;
        esac
    done
}

main
